rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isImageUploadUnder5MB() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isMarketPostMediaUpload() {
      return request.resource != null
        && request.resource.size < 250 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    function isMarketSoundUpload() {
      return request.resource != null
        && request.resource.size < 40 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    // Product images (legacy/current path requested)
    match /product_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImageUploadUnder5MB();
    }

    // Profile pictures
    // Public read so avatars load for all users
    // Only owner can upload/update/delete their own profile pictures
    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImageUploadUnder5MB();
    }

    // Store images (logo/banner)
    match /store_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImageUploadUnder5MB();
    }

    // Product images
    match /products/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImageUploadUnder5MB();
    }

    // Market message images
    match /marketMessages/{chatId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Market post images
    match /marketPosts/{postId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isMarketPostMediaUpload();
    }

    // Market sounds
    match /marketSounds/{ownerId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(ownerId) && isMarketSoundUpload();
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
